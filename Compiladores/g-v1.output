Grammar

    0 $accept: Programa $end

    1 Programa: PRINCIPAL Bloco

    2 Bloco: '{' ListaComando '}'
    3      | VarSection '{' ListaComando '}'

    4 VarSection: ListaDeclVar

    5 ListaDeclVar: IDENTIFICADOR DeclVar ':' Tipo ';' ListaDeclVar
    6             | IDENTIFICADOR DeclVar ':' Tipo ';'

    7 DeclVar: ε
    8        | ',' IDENTIFICADOR DeclVar

    9 Tipo: INT
   10     | CAR

   11 ListaComando: Comando
   12             | Comando ListaComando

   13 Comando: ';'
   14        | Expr ';'
   15        | LEIA IDENTIFICADOR ';'
   16        | ESCREVA Expr ';'
   17        | ESCREVA CADEIACARACTERES ';'
   18        | NOVALINHA ';'
   19        | SE '(' Expr ')' ENTAO ListaComando FIMSE
   20        | SE '(' Expr ')' ENTAO ListaComando SENAO ListaComando FIMSE
   21        | ENQUANTO '(' Expr ')' Comando
   22        | Bloco

   23 Expr: OrExpr
   24     | IDENTIFICADOR '=' Expr

   25 OrExpr: OrExpr OU AndExpr
   26       | AndExpr

   27 AndExpr: AndExpr E EqExpr
   28        | EqExpr

   29 EqExpr: EqExpr IGUAL DesigExpr
   30       | EqExpr DIFERENTE DesigExpr
   31       | DesigExpr

   32 DesigExpr: DesigExpr '<' AddExpr
   33          | DesigExpr '>' AddExpr
   34          | DesigExpr MAIORIGUAL AddExpr
   35          | DesigExpr MENORIGUAL AddExpr
   36          | AddExpr

   37 AddExpr: AddExpr '+' MulExpr
   38        | AddExpr '-' MulExpr
   39        | MulExpr

   40 MulExpr: MulExpr '*' UnExpr
   41        | MulExpr '/' UnExpr
   42        | UnExpr

   43 UnExpr: '-' PrimExpr
   44       | '!' PrimExpr
   45       | PrimExpr

   46 PrimExpr: IDENTIFICADOR
   47         | CARCONST
   48         | INTCONST
   49         | '(' Expr ')'


